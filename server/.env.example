# --- Firebase Admin SDK ---
# Generate at: Firebase Console > Project Settings > Service Accounts >
# Generate new private key. Downloads a JSON file - either point to its path
# or paste the whole JSON as a single-line string (escape newlines in
# private_key as \n, which is how Firebase exports it already).
FIREBASE_SERVICE_ACCOUNT_JSON=./service-account.json

# --- Cloudinary ---
# Same cloud name as the frontend .env. The API key/secret are required here
# (server-side only - never expose these in frontend code) because verifying
# Cloudinary's moderation webhook signature needs the API secret.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Stripe ---
# Get these from the Stripe Dashboard (use TEST keys while developing -
# they start with sk_test_ / pk_test_ / whsec_ from a test webhook endpoint).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Dashboard > Product catalog (create one recurring
# price per paid tier - Plus and Pro).
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PRO=price_...

# Where Stripe Checkout redirects back to after success/cancel
CLIENT_URL=http://localhost:5173

# Port for this server
PORT=8787
